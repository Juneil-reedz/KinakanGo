# Server
PORT=4000
NODE_ENV=development

# Supabase PostgreSQL — get this from Supabase → Settings → Database → Connection string (URI mode)
# For local dev you can also use: postgresql://postgres:password@localhost:5432/kinakango
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string

# Frontend URL for CORS (e.g. https://juneil-reedz.github.io)
CLIENT_URL=http://localhost:5173
